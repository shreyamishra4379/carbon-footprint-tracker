      </div>
    </div>
  </div>
</div>


<script>
function animateCounter(id, endValue, duration = 1500) {
    let start = 0;
    let increment = endValue / (duration / 16);
    let counter = document.getElementById(id);

    function update() {
        start += increment;
        if (start < endValue) {
            counter.innerText = start.toFixed(2);
            requestAnimationFrame(update);
        } else {
            counter.innerText = endValue;
        }
    }
    update();
}

animateCounter("totalCarbon", 13.8);
</script>
